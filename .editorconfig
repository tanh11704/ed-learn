root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.java]
indent_style = space
indent_size = 4
tab_width = 4
continuation_indent_size = 8

[*.py]
indent_style = space
indent_size = 4

[*.dart]
indent_style = space
indent_size = 2

[*.{yml,yaml,json,xml,md,html,css,js}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false